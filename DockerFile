# 1. aarch64(arm64) 아키텍처 및 Ubuntu 24.04 호환 베이스 이미지 사용
FROM myoung34/github-runner:ubuntu-noble

# 2. 패키지 설치 및 권한 설정을 위해 root 권한 전환
USER root

# 3. CI/CD 및 로그 기록을 위한 시스템 타임존 설정 (KST)
ENV TZ=Asia/Seoul

# 4. 대화형 프롬프트 무시 환경변수 설정 및 필수 패키지 설치
# 근거: tzdata(타임존), openjdk-17-jdk(Spring 빌드용), docker.io(DooD 구성용) 설치 및 캐시 제거
RUN DEBIAN_FRONTEND=noninteractive apt-get update && apt-get install -y \
    tzdata \
    openjdk-17-jdk \
    docker.io \
    curl \
    jq \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 5. 설정한 TZ 환경변수를 시스템 로컬타임으로 심볼릭 링크 연결
# 근거: tzdata 설치 후 OS 수준에서 변경된 타임존을 확실히 적용
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 6. [핵심 추가] DooD 작동을 위한 권한 부여
# 근거: runner 계정이 호스트의 docker.sock 파일에 접근하여 컨테이너를 제어할 수 있도록 docker 그룹에 편입
RUN usermod -aG docker runner

# 7. 보안 및 러너 실행 정책에 따라 기본 사용자로 복귀
USER runner